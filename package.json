		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.4.13",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"autoprefixer": "^10.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"reading-time": "^1.5.0",
		"tailwindcss": "4.2.4",
		"typescript": "^6.0.3"
