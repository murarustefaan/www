---
import { socialLinks } from "@/data/social";
---

<div class="flex flex-wrap gap-3">
	{
		socialLinks.map(({ label, href, icon }) => (
			<a
				href={href}
				target="_blank"
				rel="noreferrer noopener"
				class="flex items-center gap-2 px-4 py-2 bg-card border border-border rounded text-text hover:border-primary/50 hover:text-primary transition-colors"
			>
				<span class="w-[18px] h-[18px]"><Fragment set:html={icon} /></span>
				<span class="text-sm">{label}</span>
			</a>
		))
	}
</div>
