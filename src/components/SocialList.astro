---
const socialLinks = [
	{
		friendlyName: "GitHub",
		link: "https://github.com/murarustefaan",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
	},
	{
		friendlyName: "LinkedIn",
		link: "https://www.linkedin.com/in/murarustefan/",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
	},
	{
		friendlyName: "Email",
		link: "mailto:hello@stefanmuraru.com",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
	},
];
---

<div class="flex flex-wrap gap-3">
	{
		socialLinks.map(({ friendlyName, link, icon }) => (
			<a
				href={link}
				target="_blank"
				rel="noreferrer noopener"
				class="flex items-center gap-2 px-4 py-2 bg-card border border-border rounded text-text hover:border-primary/50 hover:text-primary transition-colors"
			>
				<Fragment set:html={icon} />
				<span class="text-sm">{friendlyName}</span>
			</a>
		))
	}
</div>
