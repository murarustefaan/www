---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border py-8">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted font-['JetBrains_Mono']">
		<div>
			&copy; {year} {siteConfig.author}
		</div>
		<div class="text-xs">
			Built with <a href="https://astro.build" class="text-primary hover:text-accent transition-colors" target="_blank" rel="noreferrer noopener">Astro</a>
		</div>
	</div>
</footer>
